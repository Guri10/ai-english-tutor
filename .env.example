NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
OPENAI_API_KEY=

# Server-only, bypasses RLS — used only by app/api/cron/session-maintenance
# (the abandoned-session sweep / pending_summary retry job). From Supabase
# dashboard: Project Settings > API > service_role key. Never expose this to
# the client (no NEXT_PUBLIC_ prefix, never sent to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the Supabase pg_cron/pg_net-scheduled call to
# /api/cron/session-maintenance sends as a bearer token, so the route can't
# be triggered by an arbitrary request. Generate with e.g. `openssl rand
# -hex 32`; the same value must be stored in Supabase Vault (see the
# pg_cron migration) as the `cron_secret` secret.
CRON_SECRET=

# Optional. Spec §4 cost guardrail: max sessions a user can start per UTC
# calendar day. Defaults to 10 if unset.
DAILY_SESSION_CAP=
